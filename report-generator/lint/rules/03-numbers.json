[
  {
    "id": "brittle-number",
    "type": "regex",
    "level": "warning",
    "pattern": "(?i)(胁褋械\\s+\\d+|胁褋械褏\\s+\\d+|胁褋械谐芯\\s+\\d+|褋芯写械褉卸懈褌\\s+\\d+|胁泻谢褞褔邪械褌\\s+\\d+)\\s*(褋泻褉懈锌褌|泻谢邪褋褋|屑械褌芯写|褎邪泄谢|屑芯写褍谢褜|泻芯屑锌芯薪械薪褌|褎褍薪泻褑懈)",
    "message": "Hardcoded total count. Remove or use {var}.",
    "exclude_patterns": []
  },
  {
    "id": "number-comma",
    "type": "regex",
    "level": "error",
    "pattern": "(?<=\\d)\\.(?=\\d{3,})",
    "message": "Western thousand separator (decimal dot). Use Russian format: space for thousands.",
    "exclude_patterns": [
      "\\d+\\.\\d+\\-\\d+",
      "\\d+\\.\\d+\\.\\d+"
    ]
  },
  {
    "id": "number-space-decimal",
    "type": "regex",
    "level": "error",
    "pattern": "(?<=\\d)\\.(?=\\d{2}(?:\\D|$))",
    "message": "Decimal point. Use Russian comma.",
    "exclude_patterns": [
      "\\d+\\.\\d+\\-\\d+",
      "\\d+\\.\\d+\\.\\d+",
      "\\d+\\.\\d+"
    ]
  }
]